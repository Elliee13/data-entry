// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum ReportStatus {
  PENDING
  GENERATED
  SENT
  FAILED
}

enum ReportTriggerType {
  CRON
  MANUAL
  RETRY
}

enum AuditAction {
  AUTH_LOGIN_SUCCESS
  AUTH_LOGIN_FAILURE
  AUTH_LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DEACTIVATED
  ENTRY_CREATED
  ENTRY_UPDATED
  ENTRY_DELETED
  REPORT_GENERATION_STARTED
  REPORT_GENERATION_SUCCEEDED
  REPORT_GENERATION_FAILED
  REPORT_RETRY_REQUESTED
  WEEK_ARCHIVED
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  name             String
  passwordHash     String
  role             UserRole       @default(USER)
  isActive         Boolean        @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdEntries   EventEntry[]   @relation("EntriesCreated")
  updatedEntries   EventEntry[]   @relation("EntriesUpdated")
  deletedEntries   EventEntry[]   @relation("EntriesDeleted")
  triggeredReports WeeklyReport[] @relation("ReportsTriggered")
  auditLogs        AuditLog[]
}

model EventEntry {
  id                 String        @id @default(cuid())
  eventName          String
  location           String
  eventDate          String
  weather            String
  coordinator        String
  sport              String
  shirtColor         String
  totalTeams         Int
  totalShirts        Int
  shirtsSold         Int
  totalSales         Decimal       @db.Decimal(10, 2)
  costOfProduct      Decimal       @db.Decimal(10, 2)
  laborCost          Decimal       @db.Decimal(10, 2)
  travelCost         Decimal       @db.Decimal(10, 2)
  age5u              Int
  age6u              Int
  age7u              Int
  age8u              Int
  age9u              Int
  age10u             Int
  age11u             Int
  age12u             Int
  age13u             Int
  age14u             Int
  age15u             Int
  age16u             Int
  weekKey            String
  weekStartsAt       DateTime
  weekEndsAt         DateTime
  isArchived         Boolean       @default(false)
  archivedAt         DateTime?
  archivedByReportId String?
  createdById        String
  updatedById        String?
  deletedAt          DateTime?
  deletedById        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  createdBy          User          @relation("EntriesCreated", fields: [createdById], references: [id])
  updatedBy          User?         @relation("EntriesUpdated", fields: [updatedById], references: [id])
  deletedBy          User?         @relation("EntriesDeleted", fields: [deletedById], references: [id])
  archivedByReport   WeeklyReport? @relation("EntriesArchivedByReport", fields: [archivedByReportId], references: [id])

  @@index([weekKey, isArchived, deletedAt])
  @@index([eventDate])
  @@index([createdById])
  @@index([archivedByReportId])
}

model WeeklyReport {
  id              String         @id @default(cuid())
  weekKey         String         @unique
  weekStartsAt    DateTime
  weekEndsAt      DateTime
  status          ReportStatus   @default(PENDING)
  triggerType     ReportTriggerType
  triggeredById   String?
  emailTo         String
  emailFrom       String
  emailSubject    String
  entryCount      Int            @default(0)
  csvFilename     String
  xlsxFilename    String
  emailMessageId  String?
  attemptCount    Int            @default(0)
  lastAttemptAt   DateTime?
  sentAt          DateTime?
  archivedAt      DateTime?
  failureMessage  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  triggeredBy     User?          @relation("ReportsTriggered", fields: [triggeredById], references: [id])
  archivedEntries EventEntry[]   @relation("EntriesArchivedByReport")

  @@index([status, weekStartsAt])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String?
  actorUserId String?
  actorEmail String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())
  actorUser  User?       @relation(fields: [actorUserId], references: [id])

  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
}
